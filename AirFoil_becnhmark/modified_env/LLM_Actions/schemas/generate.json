{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Generate Shape",
  "description": "Generate a new airfoil shape from scratch using linear sampling from provided bounds.",
  "type": "object",
  "properties": {
    "n_cp": {
      "type": "integer",
      "description": "Number of control points."
    },
    "n_sp": {
      "type": "integer",
      "description": "Bezier sampling resolution (e.g., 10)."
    },
    "params": {
      "type": "array",
      "description": "List of [x, y, radius, edgy] per control point. Each value can be a float or [lo, hi] for linear sampling.",
      "items": {
        "type": "array",
        "items": {
          "anyOf": [
            { "type": "number" },
            { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number" } }
          ]
        },
        "minItems": 4,
        "maxItems": 4
      }
    },
    "name": {
      "type": "string",
      "description": "Base name for the file (default: 'shape')."
    }
  },
  "required": ["n_cp", "n_sp", "params"]
}
